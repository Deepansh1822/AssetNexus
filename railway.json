{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "mvn -f backend/pom.xml clean package -DskipTests"
  },
  "deploy": {
    "startCommand": "java -jar backend/target/AssetManagement-0.0.1-SNAPSHOT.jar",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
